# Reddit OAuth (script app) — https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# For password grant (acting as the bot user, e.g. for private subs you mod):
REDDIT_USERNAME=
REDDIT_PASSWORD=
# REQUIRED: descriptive User-Agent. Reddit may rate-limit/block generic UAs.
# Format: <platform>:<app_id>:<version> (by /u/<your_username>)
REDDIT_USER_AGENT=linux:com.example.collector:0.1.0 (by /u/your_bot_username)

# Postgres
DATABASE_URL=postgresql://reddit:reddit@localhost:5432/reddit

# Optional: object storage for raw payload archive (S3 or GCS URI base)
RAW_PAYLOAD_URI_BASE=

# Logging
LOG_LEVEL=INFO
